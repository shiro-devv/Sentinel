# Environment Variables for Sentinel Backend

# Application
APP_NAME=Sentinel
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/disaster_detector
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=300

# API Keys
USGS_API_BASE_URL=https://earthquake.usgs.gov/fdsnws/event/1/query
OPENWEATHER_API_KEY=bd5e378503939ddaee76f12ad7a97608
OPENWEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Alert Thresholds - Earthquake
EARTHQUAKE_LOW_THRESHOLD=4.0
EARTHQUAKE_MEDIUM_THRESHOLD=5.5
EARTHQUAKE_HIGH_THRESHOLD=6.5
EARTHQUAKE_CRITICAL_THRESHOLD=7.5

# Alert Thresholds - Wind Speed (mph)
WIND_SPEED_LOW_THRESHOLD=39.0
WIND_SPEED_MEDIUM_THRESHOLD=57.0
WIND_SPEED_HIGH_THRESHOLD=74.0
WIND_SPEED_CRITICAL_THRESHOLD=111.0

# Alert Thresholds - Rainfall (mm/hour)
RAINFALL_LOW_THRESHOLD=2.5
RAINFALL_MEDIUM_THRESHOLD=7.5
RAINFALL_HIGH_THRESHOLD=15.0
RAINFALL_CRITICAL_THRESHOLD=50.0

# Polling Intervals (seconds)
EARTHQUAKE_POLL_INTERVAL=60
WEATHER_POLL_INTERVAL=60

# Anomaly Detection
ANOMALY_WINDOW_SIZE=24
ANOMALY_DEVIATION_MULTIPLIER=2.0

# Prediction
PREDICTION_LOOKBACK_HOURS=48
PREDICTION_FORECAST_HOURS=6

# WebSocket
WS_HEARTBEAT_INTERVAL=30

# Notifications
SMS_ENABLED=true
EMAIL_ENABLED=true
NOTIFICATION_LOG_PATH=./logs/notifications.log
